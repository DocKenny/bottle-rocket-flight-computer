menu "Zephyr Kernel"
source "$ZEPHYR_BASE/Kconfig.zephyr"

config DATA_PROCESSING_THREAD_STACK_SIZE
    int "Data processing thread stack size"
    default 2048

config DATA_PROCESSING_THREAD_PRIORITY
    int "Data processing thread priority"
    default 5

config BLE_ADVERTISEMENT_TIME_SEC
    int "Bluetooth advertisement time in seconds"
    default 300

config FLIGHT_STATIONARY_WINDOW_MS
    int "Stationary detection window (ms)"
    default 3000
    help
      The continuous duration in milliseconds that the accelerometer
      magnitude must remain stable to trigger a landing event.

config FLIGHT_G_TARGET_X100
    int "Gravity target multiplied by 100"
    default 981
    help
      The target G magnitude (scaled by 100). E.g., 981 represents 9.81 m/s^2.

config FLIGHT_STATIONARY_TOLERANCE_X100
    int "Stationary tolerance multiplied by 100"
    default 40
    help
      The allowable variance above or below the G target (scaled by 100).
      E.g., 40 represents +/- 0.40 m/s^2 variance.

config FLIGHT_WAKEUP_THRESHOLD_UG
    int "Wake-up motion threshold (micro-Gs)"
    default 500000
    help
      The acceleration threshold in micro-Gs required to wake the sensor
      and trigger the flight state.
      1000000 uG = 1G.

endmenu
